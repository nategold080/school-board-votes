# OpenAI API Key (used for LLM extraction pipeline)
OPENAI_API_KEY=sk-your-key-here

# GitHub Token (for repository management)
GITHUB_TOKEN=ghp_your-token-here

# Database path (defaults to data/database.sqlite)
DATABASE_PATH=data/database.sqlite

# Scraping settings
SCRAPE_DELAY_SECONDS=1.5
USER_AGENT=SchoolBoardVoteTracker/1.0 (Research Project; contact@example.com)

# Extraction settings
EXTRACTION_MODEL_STAGE1=gpt-4o-mini
EXTRACTION_MODEL_STAGE2=gpt-4o
MAX_RETRIES=3
